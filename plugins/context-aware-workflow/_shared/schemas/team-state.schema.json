{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Team State Schema",
  "description": "State tracking for Agent Teams orchestration in /cw:team",
  "type": "object",
  "required": ["schema_version", "team_name", "active"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "team_name": {
      "type": "string",
      "description": "Unique team identifier"
    },
    "active": {
      "type": "boolean",
      "description": "Whether the team is currently active"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "agent", "status"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["planner", "builder", "reviewer", "fixer"]
          },
          "agent": {
            "type": "string",
            "description": "Agent file name (e.g. builder.md)"
          },
          "worktree": {
            "type": ["string", "null"],
            "description": "Worktree path if isolated"
          },
          "status": {
            "type": "string",
            "enum": ["idle", "working", "done", "error"]
          },
          "teammate_id": {
            "type": ["string", "null"],
            "description": "Agent Teams teammate session ID"
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Task identifier (e.g. step ID from task_plan.md)"
          },
          "description": {
            "type": "string"
          },
          "assigned_to": {
            "type": ["string", "null"],
            "description": "Role or teammate_id assigned to this task"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "review", "done", "blocked"]
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Task IDs that must complete before this one"
          }
        }
      }
    },
    "quality_gates": {
      "type": "object",
      "properties": {
        "require_review": {
          "type": "boolean",
          "default": true
        },
        "min_reviewers": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "debate_mode": {
          "type": "boolean",
          "default": false,
          "description": "Enable reviewer cross-validation via SendMessage"
        }
      }
    },
    "synthesis": {
      "type": "object",
      "description": "Results after team synthesize",
      "properties": {
        "merged_branches": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflicts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  }
}
